# PostgreSQL接続文字列（Neon等のマネージドDBでも自前でも、ここを差し替えるだけ）
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# メール取得エンドポイント(/api/mail/fetch)を叩くマシン用トークン。
# 常駐ワーカー/Cronは x-worker-token ヘッダにこの値を付けて呼ぶ。未設定なら取得APIは常に401。
WORKER_TOKEN="change-me-to-a-long-random-string"

# 添付ファイルのローカル保存先ディレクトリ（未設定なら <プロジェクト>/var/attachments）。
STORAGE_DIR="./var/attachments"

# 添付1ファイルの上限バイト数（未設定なら 26214400 = 25MiB）。超過分は保存せずスキップ。
ATTACHMENT_MAX_BYTES="26214400"
