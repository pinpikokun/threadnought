# PostgreSQL接続文字列（Neon等のマネージドDBでも自前でも、ここを差し替えるだけ）
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# メール取得エンドポイント(/api/mail/fetch)を叩くマシン用トークン。
# 常駐ワーカー/Cronは x-worker-token ヘッダにこの値を付けて呼ぶ。未設定なら取得APIは常に401。
WORKER_TOKEN="change-me-to-a-long-random-string"

# 添付ファイルのローカル保存先ディレクトリ（未設定なら <プロジェクト>/var/attachments）。
STORAGE_DIR="./var/attachments"

# 添付1ファイルの上限バイト数（未設定なら 26214400 = 25MiB）。超過分は保存せずスキップ。
ATTACHMENT_MAX_BYTES="26214400"

# Web Push (VAPID)。`npx web-push generate-vapid-keys` で生成して差し替える。
# 未設定ならブラウザ通知(プッシュ購読/配信)は無効化される(アプリ内SSE通知は影響なし)。
# VAPID_PRIVATE_KEY は秘密。コミットしないこと(実値は .env に置く)。
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# 窓口の認証情報(IMAP/SMTPパスワード)をDB内で暗号化するための鍵(AES-256-GCM)。
# base64エンコードの32バイト。生成: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 秘密。コミットしないこと(実値は .env に置く)。未設定でも既存の平文configは読めるが、暗号化保存はできない。
CONFIG_ENCRYPTION_KEY=""
